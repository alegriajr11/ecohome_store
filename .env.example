# --- Servidor ---
# Puerto HTTP de la API (Postman: baseUrl = http://localhost:<PORT>)
PORT=3000

# --- PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecohome_store
DB_USER=postgres
DB_PASS=contraseña_de_la_base_de_datos

# --- JWT ---
JWT_SECRET=llave_secreta_para_el_token

JWT_EXPIRES_IN=1h

# --- Seed: usuario administrador inicial (solo scripts/seed.js) ---
ADMIN_SEED_USERNAME=ecohome_admin
ADMIN_SEED_EMAIL=admin@ecohome.local
ADMIN_SEED_PASSWORD=contraseña_del_admin
